# Feishu App credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Bot user ID (open_id of the bot itself, for filtering self-messages)
BOT_OPEN_ID=

# Base path to scan for git repos (required, no default)
REPO_BASE_PATH=

# SQLite database path
DB_PATH=./data/coding_partner.db

# Optional prefix for all created Feishu dev group names
# Example: GROUP_NAME_PREFIX=[CodingPartner]
GROUP_NAME_PREFIX=

# Agent provider: claude or codex
AGENT_PROVIDER=claude

# Claude CLI path (optional, defaults to "claude")
CLAUDE_CLI=claude

# Codex CLI path (optional, defaults to "codex")
CODEX_CLI=codex

# Optional Codex model override
# CODEX_MODEL=

# Log level
LOG_LEVEL=INFO

# --- Agent execution (optional, sensible defaults) ---
# AGENT_TIMEOUT=1800
# CLAUDE_TIMEOUT=1800
# STREAM_IDLE_TIMEOUT=600
# BRANCH_NAME_MODEL=haiku
# Permission mode: "auto" = all tools auto-approved;
# "confirm" = read-only analysis first, then Feishu card approval before code changes
# PERMISSION_MODE=auto

# --- Streaming UI (optional) ---
# STREAM_COOLDOWN=3.0
# CARD_STREAMING_MAX_LEN=2000
# CARD_RESULT_MAX_LEN=3000
# TOOL_ACTIVITY_LIMIT=8

# --- Housekeeping (optional) ---
# SEEN_MESSAGE_MAX_AGE=3600
# CLEANUP_INTERVAL=600
# REPO_SCAN_MAX_DEPTH=5
